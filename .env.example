# Google Gemini API Key (기본 판사, 무료)
# https://aistudio.google.com 에서 발급
GOOGLE_AI_API_KEY=AIza...

# Claude AI API Key (Claude 판사 선택 시 필요, 유료)
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-여기에키입력

# Supabase
# https://supabase.com 에서 프로젝트 생성 후
# Project Settings > API 에서 확인
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 탈퇴 유예 만료분 자동 삭제 Cron 보호용 시크릿.
# Vercel Cron이 Authorization: Bearer <CRON_SECRET> 로 호출한다.
CRON_SECRET=아무_랜덤_문자열

# 신고 목록 조회(GET /api/admin/reports) 보호용 시크릿.
# x-admin-secret 헤더로 전달.
ADMIN_SECRET=아무_랜덤_문자열
MESHY_API_KEY
